# Alternative Dockerfile using newer Debian Bookworm base
# Use this if the main Dockerfile has persistent network issues
FROM python:3.10.11-bookworm

# Set working directory
WORKDIR /app

# Configure apt for better network resilience
RUN echo 'Acquire::Retries "5";' > /etc/apt/apt.conf.d/80-retries && \
    echo 'Acquire::http::Timeout "300";' >> /etc/apt/apt.conf.d/80-retries && \
    echo 'APT::Install-Recommends "false";' >> /etc/apt/apt.conf.d/80-retries

# Install system dependencies in stages to reduce timeout risk
RUN apt-get clean && rm -rf /var/lib/apt/lists/*

RUN apt-get update --fix-missing || apt-get update --fix-missing

RUN apt-get install -y --no-install-recommends --fix-missing \
    git wget ca-certificates && \
    rm -rf /var/lib/apt/lists/* && apt-get clean

RUN apt-get update --fix-missing && \
    apt-get install -y --no-install-recommends --fix-missing \
    libgl1 libglib2.0-0 libsm6 libxrender1 libxext6 libgomp1 && \
    rm -rf /var/lib/apt/lists/* && apt-get clean

# Copy requirements files
COPY requirements.txt requirements_versions.txt ./
COPY requirements-test.txt ./

# Upgrade pip and install specific build tools
RUN python -m pip install --upgrade pip --retries 5 --timeout 300 && \
    pip install setuptools==68.2.2 wheel --retries 5 --timeout 300

# Install NumPy with specific version for compatibility
RUN pip install numpy==1.26.4 --retries 5 --timeout 300

# Install PyTorch (CPU version for compatibility with your setup)
RUN pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu --retries 5 --timeout 300

# Install CLIP manually without build isolation
RUN pip install git+https://github.com/openai/CLIP.git --no-build-isolation --retries 5 --timeout 300

# Install main requirements
RUN pip install -r requirements.txt --retries 5 --timeout 300

# Copy the entire application
COPY . .

# Create necessary directories
RUN mkdir -p models/Stable-diffusion models/VAE models/GFPGAN models/ESRGAN \
    models/BSRGAN models/RealESRGAN models/Codeformer models/LDSR models/SwinIR \
    models/ScuNET models/Lora models/hypernetworks embeddings outputs cache config_states \
    extensions repositories

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV GRADIO_SERVER_NAME=0.0.0.0
ENV COMMANDLINE_ARGS="--use-cpu all --precision full --no-half --skip-torch-cuda-test --listen --api --share"
ENV PIP_DEFAULT_TIMEOUT=300
ENV PIP_RETRIES=5

# Expose port for web interface
EXPOSE 7860

# Verify installation
RUN python -c "import torch, clip, numpy; print('Environment OK')"

# Run the application
CMD ["python", "launch.py"]
